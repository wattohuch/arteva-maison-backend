# Arteva Maison Print Station Configuration - Smart Real-time Edition
# Copy this file to .env and configure for your setup

# API Configuration
API_URL=https://arteva-maison-backend.onrender.com
API_KEY=your_admin_api_key_here

# Socket.io Configuration (optional, defaults to API_URL)
SOCKET_URL=https://arteva-maison-backend.onrender.com

# Connection Settings
RECONNECT_ATTEMPTS=10          # Number of reconnection attempts
RECONNECT_DELAY=5000           # Delay between reconnection attempts (ms)
FALLBACK_POLL_INTERVAL=60000   # Fallback polling interval when Socket.io fails (ms)

# Print Station Identity
PRINT_STATION_ID=ps-kitchen     # Unique ID for this print station (e.g., ps-kitchen, ps-warehouse)

# Printer Configuration
PRINTER_INTERFACE=/dev/usb/lp0  # USB printer path (Linux)
# For network printer use: tcp://192.168.1.100:9100
# For serial printer use: /dev/ttyUSB0

PRINTER_TYPE=EPSON  # Options: EPSON, STAR, TANCA, DARUMA, BEMATECH

# Print Options
PRINT_RECEIPT=true      # Print customer receipt
PRINT_LABEL=true        # Print shipping label
PRINT_PACKING=true      # Print packing slip

# File Paths
LOG_FILE=./logs/print-station.log
STATE_FILE=./data/last-order.json

# Test Mode
TEST_MODE=false  # Set to true to print a test order and exit

# Optional: Notification Settings
NOTIFY_ON_ERROR=true
NOTIFY_EMAIL=admin@artevamaison.com
NOTIFY_WEBHOOK=  # Webhook URL for notifications
